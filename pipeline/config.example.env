# Copy to .env and fill in. Never commit real keys.

# Which backend to use: groq (free tier, fast), openai (your key), or
# mock (fully offline  -  no network/key/SDK; scripted responses for testing).
# Groq and OpenAI share the same API dialect, so switching between them is just
# this one line; model names default sensibly per provider (see providers.py).
PROVIDER=groq

# --- Keys (only the selected PROVIDER's key is required) ---
# Get a free Groq key at https://console.groq.com, or use an OpenAI key.
GROQ_API_KEY=
OPENAI_API_KEY=
# Only required if you route STT/TTS to Deepgram (see per-stage overrides below).
DEEPGRAM_API_KEY=

# --- Per-stage speech overrides (optional): mix vendors per stage ---
# PROVIDER above picks the LLM; STT_PROVIDER / TTS_PROVIDER route just that stage
# to another vendor: deepgram | openai | groq. Blank = follow PROVIDER; a value
# equal to PROVIDER is a no-op. Any combination works (e.g. Groq LLM + OpenAI STT
# + Deepgram TTS). Each vendor you name needs ITS key set above (checked at boot).
# Deepgram needs the extra: `uv sync --extra live --extra deepgram`.
# STT_PROVIDER=deepgram          # deepgram = Nova-3 (multilingual EN+ES by default)
# TTS_PROVIDER=deepgram          # honored only when TTS_BACKEND=provider
#
# The generic knobs bind to whichever vendor OWNS that stage after overrides
# (blank -> that owner's preset default; blank them when switching stage owners):
#   STT_MODEL    -> the STT owner's model (deepgram default nova-3)
#   STT_LANGUAGE -> the STT owner's language hint (deepgram default multi)
#   TTS_MODEL    -> the TTS owner's model (openai gpt-4o-mini-tts; deepgram has none, its voice IS the model)
#   TTS_VOICE    -> the TTS owner's voice (openai alloy; deepgram English voice aura-2-luna-en)
#   TTS_VOICE_ES -> Spanish voice for single-language-voice vendors (deepgram aura-2-celeste-es; openai ignores it)
# Aura-2 voices are single-language, so the agent picks the EN vs ES voice per turn.
# Vocab biasing (Vera, room names) is applied to Deepgram STT automatically; transient
# Deepgram connection drops are retried once.
# TTS_VOICE_ES=aura-2-celeste-es
# STT_LANGUAGE=multi    # set en for lower STT latency (drops ES code-switching)

# --- Optional model overrides (leave blank to use the provider's defaults) ---
# groq defaults:  llama-3.3-70b-versatile / whisper-large-v3-turbo / canopylabs/orpheus-v1-english
# openai defaults: gpt-4.1-mini / gpt-4o-mini-transcribe / gpt-4o-mini-tts
# Example Groq override: llama-3.1-8b-instant for lower latency and weaker tools.
LLM_MODEL=
# REASONING_EFFORT=none      # only used if you override LLM_MODEL to a gpt-5*/o-series reasoning model
STT_MODEL=
# Optional multilingual hotel vocabulary supplied to STT as transcription context.
STT_PROMPT=
TTS_MODEL=
TTS_VOICE=
TTS_INSTRUCTIONS=

# TTS backend: "provider" (cloud TTS) or "system" (local voice command).
# Groq TTS is in preview and needs terms accepted in the console; if it errors,
# set TTS_BACKEND=system to keep the demo moving at zero cost.
TTS_BACKEND=provider
SYSTEM_TTS_CMD=say
AUDIO_PLAYER_CMD=afplay

# --- Loop tuning (safe defaults) ---
VAD_AGGRESSIVENESS=2     # 0-3, higher = more aggressive silence detection
ENDPOINT_SILENCE_MS=600  # pause length that ends the caller's turn
MIN_SPEECH_MS=200        # drop captures with less voiced audio than this (noise)
SAMPLE_RATE=16000

# --- Low-latency profile (opt-in; trades some quality/robustness for speed) ---
# Defaults favor tool-calling reliability and demo quality. To cut per-turn
# latency, uncomment (see PRODUCTION_NOTES.md "Latency" for the budget):
#   LLM_MODEL=llama-3.1-8b-instant   # groq: ~2-3x faster than 70b, weaker tools
#   LLM_MODEL=gpt-4.1-nano           # openai alternative to gpt-4.1-mini
#   TTS_BACKEND=system               # local `say` -> no cloud TTS round-trip, $0
#   ENDPOINT_SILENCE_MS=450          # end turns sooner (more false endpoints)

# Stream the LLM reply and speak it sentence-by-sentence as it is generated,
# cutting time-to-first-audio in BOTH the CLI voice_loop and the browser demo
# (the browser gets NDJSON sentence chunks + progressive playback; the header
# badge flips to "Streaming cascade" when a turn actually streamed). Opt-in;
# needs a live provider + cloud TTS -- the mock and TTS_BACKEND=system ignore
# it, so the offline path stays batch. "off" (default) = unchanged behavior.
STREAMING=off

# Optional JSONL trace destination. Leave blank to keep telemetry in memory.
TELEMETRY_JSONL=../logs/voice-events.jsonl
TELEMETRY_INCLUDE_CONTENT=false

# --- Optional local LiveKit room/session demo ---
# Defaults match `livekit/start_local_server.sh`.
LIVEKIT_URL=http://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_ROOM=vera-demo-room
