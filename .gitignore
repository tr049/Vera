# Python
__pycache__/
*.py[cod]

# uv virtual environment (NOTE: uv.lock and .python-version ARE committed)
.venv/
venv/

# Secrets / local env — config.example.env stays tracked as the template.
# Cover .env plus .env.* variants and common secret filenames so protection does
# not depend on a machine-local global gitignore (which a fresh clone won't have).
.env
**/.env
.env.*
**/.env.*
*.pem
*.key
*.p12
secrets.json

# Runtime telemetry (talk_server.py writes logs/voice-events.jsonl here)
logs/

# Node deps for the LiveKit browser demo
node_modules/

# macOS / JetBrains
.DS_Store
.idea/

# Internal docs — kept locally, excluded from the published repository
ARCHITECTURE.md
CLAUDE.md
